# This file serves as an example of what your .env file should look like.
# Replace the variables defined here with those applicable on your own system.
# Then copy the contents into a file called ".env" and place it in project's
# root directory.

# WRDS PostgreSQL access — used by:
#   - pull_wrds_earning_transcripts.py  (Capital IQ transcripts)
#   - pull_CRSP_stock.py / pull_CRSP_Compustat.py
# The wrds Python library reads ~/.pgpass automatically; no password
# needed here unless you want to override.
WRDS_USERNAME=jdoe

# OpenAI — used by:
#   - embed_transcripts.py + score_transcript_sentiment.py
#       (text-embedding-3-small for earnings-call sentiment)
#   - embed_sec_10q_text.py  (optional 10-Q embeddings)
#   - analyze_sec_10q_llm.py (optional generative-AI 10-Q analysis, V4/V5)
# Required for the full sentiment pipeline; smoke tests can use --synthetic.
OPENAI_API_KEY=

# Generative-AI 10-Q analysis layer (analyze_sec_10q_llm.py) — optional.
# Model used for the structured 10-Q disclosure-change analysis, and the
# earliest filing year to analyze (bounds API cost). Defaults shown.
SEC_10Q_LLM_MODEL=gpt-4o-mini
SEC_10Q_LLM_START_YEAR=2014

# 10-Q SEC EDGAR pulls — no auth required (HTTPS + User-Agent only).
# Override the SEC contact identifier sent in every request if you fork.
SEC_EDGAR_USER_AGENT="Your Name your.email@example.com"

# Caching — applies to the SEC pull's local file cache.
USE_CACHE=true

# Bloomberg Terminal access — used by src/pull_bloomberg_via_api.py.
# true  -> script connects to Bloomberg via blpapi and overwrites the cache
#          at data_manual/bbg/. Requires Terminal running on this machine.
# false (or unset) -> script is a no-op for the Bloomberg call; it just
#          hydrates _data/ from the committed cache at data_manual/bbg/.
BLOOMBERG_TERMINAL_AVAILABLE=false
