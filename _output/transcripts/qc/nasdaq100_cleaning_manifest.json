  "safe_harbor_rule_summary": {
    "max_removal_words": 350,
    "mixed_component_words": 700,
    "strong_patterns": [
      "forward[- ]looking statements?",
      "safe harbor",
      "actual results .* differ materially",
      "private securities litigation reform act"
    ],
    "supporting_patterns": [
      "risk factors",
      "sec filings?",
      "securities and exchange commission",
      "non-gaap",
      "gaap and non-gaap"
    ]
  },
  "operator_rule_summary": {
    "boilerplate_patterns": [
      "welcome to",
      "today'?s call",
      "conference call",
      "operator instructions",
      "press (star|\\\\*)",
      "question-and-answer session",
      "you may disconnect",
      "this call is being recorded",
      "stand by",
      "thank you for joining"
    ],
    "structural_operator_patterns_retained": [
      "first question",
      "next question",
      "question-and-answer session",
      "turn the call over"
    ]
  },
  "speaker_classification_rule": {
    "1": "operator",
    "2": "management",
    "3": "analyst",
    "4_or_5_or_missing": "other_unknown unless section fallback applies",
    "overrides": [
      "speaker_name == Operator => operator",
      "Question => analyst",
      "Answer => management"
    ]
  },
  "section_parsing_rule": {
    "presentation": [
